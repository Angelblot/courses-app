# Copy to .env and edit before running `docker compose up`.

# Required — 32-byte URL-safe base64 key for credential encryption.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-real-fernet-key

# Optional — host port exposed on the container
APP_PORT=8000

# Optional — CORS allow-list (comma-separated or *)
CORS_ORIGINS=*

# Optional — set true for FastAPI debug mode
DEBUG=false
